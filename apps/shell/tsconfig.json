{
    "extends": "@cohbrgr/tsconfig",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "src/*": ["./src/*"],
            "@cohbrgr/content/*": ["../content/*"]
        },
        "typeRoots": ["../../node_modules/@types", "./client/src/@types/*"],
        "lib": ["ES2022", "dom", "dom.iterable", "webworker"]
    },
    "exclude": ["../../node_modules", "./build.js", "./dist", "./eslint.config.js"]
}

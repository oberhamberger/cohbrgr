{
    "name": "cohbrgr",
    "version": "2026.3.0",
    "main": "apps/shell/dist/server",
    "author": "Christian Oberhamberger",
    "description": "temporary website gone mad",
    "private": true,
    "license": "ISC",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "keywords": [
        "express",
        "typescript",
        "react",
        "css-modules",
        "ssr"
    ],
    "scripts": {
        "bootstrap": "git clean -xfd && pnpm i && pnpm run build",
        "prettier": "prettier --write .",
        "lint": "nx run-many -t lint",
        "build": "nx run-many -t build",
        "dev": "nx run-many -t dev",
        "start": "nx run-many -t start",
        "serve": "nx run-many -t serve",
        "test": "nx run-many -t test",
        "graph": "nx graph",
        "build:compiler": "nx build @cohbrgr/build",
        "build:utils": "nx build @cohbrgr/utils",
        "build:shell": "nx build @cohbrgr/shell",
        "build:shell:analyze": "nx build:analyze @cohbrgr/shell",
        "build:figma": "nx build @cohbrgr/figma",
        "build:content": "nx build @cohbrgr/content",
        "build:api": "nx build @cohbrgr/api",
        "start:shell": "nx start @cohbrgr/shell",
        "start:content": "nx start @cohbrgr/content",
        "start:api": "nx start @cohbrgr/api",
        "dev:shell": "nx dev @cohbrgr/shell",
        "dev:content": "nx dev @cohbrgr/content",
        "dev:api": "nx dev @cohbrgr/api",
        "serve:shell": "nx serve @cohbrgr/shell",
        "serve:content": "nx serve @cohbrgr/content",
        "serve:api": "nx serve @cohbrgr/api",
        "test:components": "nx test @cohbrgr/components",
        "test:integration": "./scripts/integration-test.sh",
        "test:e2e": "pnpm --filter @cohbrgr/e2e e2e",
        "test:e2e:ui": "pnpm --filter @cohbrgr/e2e e2e:ui",
        "test:e2e:prod": "E2E_BASE_URL=https://cohbrgr.com pnpm --filter @cohbrgr/e2e e2e",
        "ship": "./scripts/deploy.sh",
        "ship:dry": "./scripts/deploy.sh --dry-run",
        "integration": "pnpm run bootstrap && pnpm run lint && pnpm run test && pnpm run test:integration && pnpm run test:e2e",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oberhamberger/cohbrgr.git"
    },
    "bugs": {
        "url": "https://github.com/oberhamberger/cohbrgr/issues"
    },
    "homepage": "https://github.com/oberhamberger/cohbrgr#readme",
    "dependencies": {
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-router": "7.15.1",
        "react-router-dom": "7.15.1"
    },
    "devDependencies": {
        "@cohbrgr/prettier": "workspace:*",
        "@commitlint/cli": "21.0.1",
        "@commitlint/config-conventional": "21.0.1",
        "@nx/js": "22.7.2",
        "@types/node": "25.8.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "husky": "9.1.7",
        "nx": "22.7.2",
        "typescript": "6.0.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@swc/core",
            "nx"
        ]
    },
    "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
    "engines": {
        "node": ">=24"
    }
}

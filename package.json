{
    "name": "cohbrgr",
    "version": "1.0.1",
    "workspaces": [
        "packages/build",
        "packages/src"
    ],
    "main": "dist/server",
    "author": "Christian Oberhamberger",
    "description": "temporary website gone mad",
    "private": true,
    "license": "ISC",
    "keywords": [
        "express",
        "typescript",
        "react",
        "css-modules",
        "ssr"
    ],
    "scripts": {
        "lerna": "lerna",
        "lernastart": "lerna run start --scope=build",
        "cleanup": "rm -rf ./dist",
        "bootstrap": "rm -rf ./node_modules && npm run cleanup && npm install",
        "lint": "eslint .eslintrc.js build && eslint .eslintrc.js src",
        "prestart": "npm run cleanup && npm run lint && npm run prettier",
        "prebuild": "npm run cleanup",
        "prettier": "node_modules/.bin/prettier --write .",
        "build:cli": "npx tsc --build ./build",
        "build": "NODE_ENV=production ts-node -r tsconfig-paths/register build",
        "build:analyze": "NODE_ENV=production ts-node -r tsconfig-paths/register build --analyze",
        "start": "NODE_ENV=development ts-node -r tsconfig-paths/register build -w",
        "test": "jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oberhamberger/cohbrgr.git"
    },
    "bugs": {
        "url": "https://github.com/oberhamberger/cohbrgr/issues"
    },
    "homepage": "https://github.com/oberhamberger/cohbrgr#readme",
    "dependencies": {
        "winston": "^3.10.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^14.0.0",
        "@tsconfig/node20": "^20.1.0",
        "@types/compression": "^1.7.2",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.3",
        "@types/node": "^20.4.2",
        "@types/react": "^18.2.15",
        "@types/react-dom": "^18.2.7",
        "@types/react-router": "^5.1.20",
        "@types/react-router-dom": "^5.3.3",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.45.0",
        "eslint-plugin-jsdoc": "^46.4.4",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "html-validate": "^8.0.5",
        "jest": "^29.6.1",
        "jest-environment-jsdom": "^29.6.1",
        "jest-transform-stub": "^2.0.0",
        "lerna": "^7.1.4",
        "node-mocks-http": "^1.12.2",
        "prettier": "^3.0.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.6"
    }
}

{
  "extends": "@tsconfig/node20/tsconfig.json",
  "include": ["./src/**/*.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Node",

    "rootDir": ".",
    "sourceMap": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "typeRoots": [
      "node_modules/@types",
      "./@types/*",
    ]
  },
  "exclude": ["node_modules", "lib"],
}

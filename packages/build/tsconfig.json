{
    "extends": "@cohbrgr/tsconfig",
    "include": ["src/**/*"],
    "compilerOptions": {
        "outDir": "dist",
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": true,
        "baseUrl": ".",
        "paths": {
            "src/*": ["./src/*"]
        },
        "typeRoots": ["node_modules/@types", "./src/@types/*", ]
    },
}

{
  "extends": "@tsconfig/node20/tsconfig.json",
  "include": ["./**/*.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "lib",
    "sourceMap": true,
    "incremental": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "typeRoots": [
      "node_modules/@types",
      "./@types/*"
    ],
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable",
      "webworker"
    ],
  },
  "exclude": [
    "./dist"
  ]
}

{
    "extends": "@cohbrgr/tsconfig",
    "compilerOptions": {
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "src/*": ["./src/*"]
        },
        "incremental": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "typeRoots": ["../../node_modules/@types", "./src/@types/*"]
    }
}

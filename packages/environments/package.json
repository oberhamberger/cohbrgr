{
    "name": "@cohbrgr/environments",
    "version": "1.2.1",
    "type": "module",
    "author": "Christian Oberhamberger",
    "license": "ISC",
    "exports": {
        ".": {
            "import": {
              "types": "./dist/index.d.ts",
              "default": "./dist/src/index.js"
            }
        }
    },
    "types": "./dist/index.d.ts",
    "typesVersions": {
        "*": {
            "*": [
                "./dist/*",
                "./dist/index.d.ts"
            ]
        }
    },
    "scripts": {
        "build": "swc src -d dist",
        "types": "tsc --emitDeclarationOnly",
        "prebuild": "npm run types"
    },
    "devDependencies": {
        "@swc/cli": "^0.6.0"
    }
}

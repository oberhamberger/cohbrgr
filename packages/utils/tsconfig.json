{
    "extends": "@cohbrgr/tsconfig",
    "compilerOptions": {
        "jsx": "react-jsx",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "typeRoots": ["../../node_modules/@types", "node_modules/@types"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}

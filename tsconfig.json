{
    "extends": "@tsconfig/node20/tsconfig.json",
    "ts-node": {},
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "build/*": ["build/*"],
            "src/*": ["src/*"]
        },
        "sourceMap": true,
        "incremental": true,
        "jsx": "react-jsx",
        "allowJs": false,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "typeRoots": [
            "./node_modules/@types",
            "./packages/build/@types/*",
            "./packages/src/@types/*"
        ],
        "lib": ["ES2022", "dom", "dom.iterable", "webworker"]
    },
    "exclude": ["./dist", "./lib"]
}

{
    "extends": "@tsconfig/node20/tsconfig.json",
    "ts-node": {},
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "packages/*": ["packages/*"]
        },
        "sourceMap": true,
        "incremental": true,
        "jsx": "react-jsx",
        "allowJs": false,
        "resolveJsonModule": true,
        "module": "CommonJS",
        "moduleResolution": "node",
        "typeRoots": ["./node_modules/@types", "./packages/build/@types/*"],
        "lib": ["ES2022", "dom", "dom.iterable", "webworker"]
    },
    "exclude": ["./dist"]
}
